<div class="container py-5">

  <%# ── Section Header %>
  <div class="mb-4">
    <h3 class="section-title">BROWSE COMMUNITY CRATES</h3>
    <p class="section-subtitle">Dig through our user-generated music library. Remix, sample, and collaborate.</p>
  </div>

  <%# ── Crate Grid %>
  <div class="crate-grid mb-5">
    <% @crates.take(4).each do |crate| %>
      <div class="crates-category"
           style="background-image: linear-gradient(rgba(0,0,0,0.45), rgba(43,11,83,0.5)), url(<%= crate.photo.attached? ? cl_image_path(crate.photo.key) : "https://source.unsplash.com/random/?music" %>)">
        <%= link_to crate.name, crate_path(crate), class: "crate-title text-decoration-none text-white" %>
      </div>
    <% end %>
  </div>

  <%# ── Originals & Remixes %>
  <div class="row g-4">
    <div class="col-12 col-lg-6">
      <h3 class="section-title">ORIGINAL WORKS</h3>
      <p class="section-subtitle">Collaborate with artists and remix their originals</p>
      <% @originals.each do |song| %>
        <%= render 'songs/card', song: song, crate_song: false %>
      <% end %>
    </div>
    <div class="col-12 col-lg-6">
      <h3 class="section-title">REMIXES</h3>
      <p class="section-subtitle">Listen to the latest collaborations</p>
      <div class="d-flex flex-wrap gap-3">
        <% @remixes.each do |song| %>
          <%= render 'songs/remix_card', song: song, crate_song: false %>
        <% end %>
      </div>
    </div>
  </div>

</div>
