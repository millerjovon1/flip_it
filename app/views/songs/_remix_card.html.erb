<div class="remix-card" data-controller="playlist-popup play-button play-slider">

  <%# ── Cover Image with overlay slider %>
  <div class="remix-audio position-relative">
    <input style="z-index:1000; bottom:0; left:0; right:0; position:absolute; width:100%; padding:0;"
           type="range" id="play-slider" min="0" value="0"
           data-action="click->play-slider#timeupdate"
           data-play-slider-target="input">
    <% if song.photo.attached? %>
      <%= cl_image_tag(song.photo.key) %>
    <% else %>
      <%= image_tag "https://source.unsplash.com/random/?music,producer", alt: song.title %>
    <% end %>
    <%# Play / Pause overlay %>
    <i class="fa-regular fa-circle-play play-button"
       data-action="click->play-button#play"
       data-play-button-target="playButton"></i>
    <i class="fa-regular fa-circle-pause pause-button d-none"
       data-action="click->play-button#pause"
       data-play-button-target="pauseButton"></i>
    <%# BPM + genre pills %>
    <div class="remix-pills">
      <span class="remix-bpm-pills-button">bpm <%= song.bpm %></span>
      <span class="remix-info-pills-button"><%= song.genre %></span>
      <span class="remix-info-pills-button"><%= song.instruments %></span>
    </div>
  </div>

  <%# ── Card Info %>
  <div class="remix-card-infos">
    <audio controls style="display:none"
           data-play-button-target="audio"
           data-play-slider-target="audio"
           data-action="timeupdate->play-slider#update">
      <source src="<%= song.audio_file.url %>" type="audio/wav">
    </audio>

    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h3 style="font-size:13px; margin-bottom:2px;">
          <%= link_to song.user.artist_name, user_path(song.user), class: "no-decoration hover-effect" %>
        </h3>
        <h3 style="font-size:12px; opacity:0.65;">
          <%= link_to song.title, song_path(song), class: "no-decoration hover-effect" %>
        </h3>
        <% if song.original.present? %>
          <p style="font-size:10px; margin-top:4px;">
            <%= link_to "Orig: #{song.original.user.artist_name}", user_path(song.original.user), class: "no-decoration hover-effect" %>
          </p>
        <% end %>
      </div>
      <small data-play-slider-target="duration" data-play-button-target="duration"
             data-action="click->play-slider#update"
             style="color:rgba(255,255,255,0.4); font-size:10px;">0:00</small>
    </div>

    <div class="remix-engagement d-flex align-items-center mt-2">
      <%= render 'songs/download_button', song: song %>
      <i class="fa-solid fa-circle-plus card-buttons" data-action="click->playlist-popup#appear"></i>
      <%= render 'songs/share_button', song: song %>
    </div>
  </div>

  <%= render 'songs/playlist_form', song: song, crate_song: @crate_song %>
</div>
<%= render 'songs/share_modal', song: song %>
