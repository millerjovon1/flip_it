<nav class="navbar navbar-expand-md navbar-lewagon fixed-top">
  <div class="container-fluid px-4 d-flex align-items-center justify-content-between">

    <%# ── Brand ──────────────────────────────────────────────────────── %>
    <div class="d-flex align-items-center gap-2" id="nav-logo">
      <%= link_to 'FLIP IT!', root_path, class: 'flip-it' %>
      <%= link_to songs_path, class: 'nav-bar-link-logo' do %>
        <%= image_tag 'Section 4.png', alt: 'Flip It Logo', class: 'logo-image' %>
      <% end %>
    </div>

    <%# ── Search ─────────────────────────────────────────────────────── %>
    <div id="nav-search" class="d-none d-md-flex align-items-center">
      <%= form_with url: search_path, method: :get, class: "d-flex" do %>
        <%= text_field_tag 'query[]',
            params[:query],
            class: "form-control",
            placeholder: "Search genre, BPM, artist..." %>
        <%= submit_tag "DIG", name: "", class: "search-button" %>
      <% end %>
    </div>

    <%# ── Nav Actions ─────────────────────────────────────────────────── %>
    <div id="nav-links" class="d-flex align-items-center gap-2">
      <% if user_signed_in? %>
        <%= link_to 'UPLOAD', new_song_path, class: 'nav-bar-link' %>

        <div class="nav-item dropdown" style="list-style:none;">
          <a href="#" class="d-flex align-items-center" id="navbarDropdown"
             data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <% if current_user.photo.attached? %>
              <%= cl_image_tag(current_user.photo.key, class: "avatar") %>
            <% else %>
              <%= image_tag "https://avatars.githubusercontent.com/u/130570205?v=4",
                  class: "avatar", alt: "Profile menu" %>
            <% end %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
            <li><%= link_to "Profile", user_path(current_user), class: "dropdown-item" %></li>
            <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
            <li><%= link_to "Log out", destroy_user_session_path,
                    data: { turbo_method: :delete }, class: "dropdown-item" %></li>
          </ul>
        </div>
      <% else %>
        <%= link_to "Log in", new_user_session_path, class: "nav-bar-link" %>
        <%= link_to "Sign up", new_user_registration_path,
            class: "nav-bar-link",
            style: "background: rgba(255,198,90,0.15); border: 1px solid rgba(255,198,90,0.4); border-radius: 6px;" %>
      <% end %>
    </div>

  </div>
</nav>
