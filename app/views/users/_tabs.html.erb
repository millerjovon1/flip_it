<ul class="nav tabs-underlined" id="myTab" role="tablist">
  <li class="nav-item" role="presentation">
    <span class="nav-link tab-underlined active" id="bookings-tab"
          data-bs-toggle="tab" data-bs-target="#bookings-tab-pane"
          role="tab" aria-controls="bookings-tab-pane" aria-selected="true">ORIGINALS</span>
  </li>
  <li class="nav-item" role="presentation">
    <span class="nav-link tab-underlined" id="requests-tab"
          data-bs-toggle="tab" data-bs-target="#requests-tab-pane"
          role="tab" aria-controls="requests-tab-pane" aria-selected="false">REMIXES</span>
  </li>
  <li class="nav-item" role="presentation">
    <span class="nav-link tab-underlined" id="conversations-tab"
          data-bs-toggle="tab" data-bs-target="#conversations-tab-pane"
          role="tab" aria-controls="conversations-tab-pane" aria-selected="false">CRATES</span>
  </li>
</ul>

<div class="tab-content pt-4" id="myTabContent">

  <%# ── Originals Tab %>
  <div class="tab-pane fade py-2 show active" id="bookings-tab-pane"
       role="tabpanel" aria-labelledby="bookings-tab" tabindex="0">
    <p class="section-subtitle">Original tracks uploaded by this artist</p>
    <% if @user.songs.any? %>
      <% @user.songs.each do |song| %>
        <%= render 'songs/card', song: song, crate_song: false %>
      <% end %>
    <% else %>
      <p style="opacity:0.5;">No original tracks yet.</p>
    <% end %>
  </div>

  <%# ── Remixes Tab %>
  <div class="tab-pane fade py-2" id="requests-tab-pane"
       role="tabpanel" aria-labelledby="requests-tab" tabindex="0">
    <p class="section-subtitle">Remixes created by this artist</p>
    <% if @user.remixes.any? %>
      <div class="d-flex flex-wrap gap-3">
        <% @user.remixes.each do |song| %>
          <%= render 'songs/remix_card', song: song, crate_song: false %>
        <% end %>
      </div>
    <% else %>
      <p style="opacity:0.5;">No remixes yet.</p>
    <% end %>
  </div>

  <%# ── Crates Tab %>
  <div class="tab-pane fade py-2" id="conversations-tab-pane"
       role="tabpanel" aria-labelledby="conversations-tab" tabindex="0">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <p class="section-subtitle mb-0">Your curated music collections</p>
      <%= link_to '+ New Crate', new_crate_path, class: 'download-pill-button' %>
    </div>
    <div class="crate-grid">
      <% @crates.each do |crate| %>
        <div class="crates-category"
             style="background-image: linear-gradient(rgba(0,0,0,0.45), rgba(43,11,83,0.5)), url(<%= crate.photo.attached? ? cl_image_path(crate.photo.key) : 'https://source.unsplash.com/random/?music' %>)">
          <%= link_to crate.name, crate_path(crate), class: "crate-title text-decoration-none text-white" %>
        </div>
      <% end %>
    </div>
  </div>

</div>
