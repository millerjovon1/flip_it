<div class="container py-5">

  <%# ── Crate Header %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-3">
      <%= link_to user_path(current_user), class: "text-decoration-none" do %>
        <i class="fas fa-arrow-left go-back-button" style="font-size:1.5rem;"></i>
      <% end %>
      <div>
        <h1 style="font-size:2rem; margin:0;"><%= @crate.name %></h1>
        <p class="section-subtitle mb-0"><%= pluralize(@crate.crate_songs.count, 'track') %></p>
      </div>
    </div>
    <%= link_to songs_path, class: "text-decoration-none" do %>
      <i class="fa-solid fa-circle-plus add-music"></i>
    <% end %>
  </div>

  <%# ── Crate Tracks %>
  <div class="d-flex flex-column align-items-center">
    <% @crate.crate_songs.each do |crate_song| %>
      <%= render 'songs/card', song: crate_song.song, crate_song: crate_song %>
    <% end %>
  </div>

</div>
